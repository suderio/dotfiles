#!/usr/bin/env bb

(require '[babashka.process :refer [shell]]
         '[babashka.fs :as fs]
         '[clojure.string :as str])

;; --- Helpers ---

(defn log [msg]
  (println (str "\n🟢 \033[1;32m" msg "\033[0m")))

(defn err [msg]
  (println (str "\n🔴 \033[1;31m" msg "\033[0m")))

(def home (str (fs/home)))

;; --- 1. Criando nossa própria "Lib" Git (Wrapper) ---

(defn git-cmd [opts & args]
  (let [base-cmd ["git"]
        base-cmd (if (:git-dir opts)
                   (concat base-cmd ["-C" (:git-dir opts)])
                   base-cmd)
        base-cmd (if (:work-tree opts)
                   (concat base-cmd ["--work-tree" (:work-tree opts)])
                   base-cmd)
        full-cmd (concat base-cmd args)

        proc-opts (merge {:out :string :err :string :continue true}
                         (select-keys opts [:dir]))]

    (let [res (apply shell proc-opts full-cmd)]

      (when (not (str/blank? (:err res)))
        (println (str "⚠️  Git output: " (str/trim (:err res)))))

      (when (and (not (:continue opts))
                 (not= 0 (:exit res)))
        (throw (ex-info "Erro Crítico no Git" {:cmd full-cmd :error (:err res)})))

      res)))

(defmulti git (fn [action & _] action))

(defmethod git :pull [_ opts]
  (println "⬇️ Git Pull...")
  (git-cmd opts "pull"))

(defmethod git :push [_ opts]
  (println "⬆️ Git Push...")
  (git-cmd opts "push"))

(defmethod git :add [_ opts files]
  (when (seq files)
    (println (str "➕ Adicionando: " (str/join ", " files)))
    (apply git-cmd opts "add" files)))

(defmethod git :commit [_ opts msg]
  (println "💾 Git Commit...")
  ;; :continue true pois o commit falha se nada mudou
  (git-cmd (assoc opts :continue true) "commit" "-m" msg))

(defmethod git :status-porcelain [_ opts]
  (let [res (git-cmd opts "status" "--porcelain")]
    (:out res)))
;; --- Comandos Específicos ---

(defn task-org []
  (log "Iniciando sincronização do ORG mode...")
  (let [org-dir (fs/file home "org")]
    (if (fs/exists? org-dir)
      (do
        (shell {:dir org-dir} "git pull")
        (shell {:dir org-dir} "git add --all")
        ;; continue: true impede que o script pare se não houver nada para commitar
        (shell {:dir org-dir :continue true} "git commit -m \"Mensagem Padrão\"")
        (shell {:dir org-dir} "git push"))
      (err (str "Diretório " org-dir " não encontrado!")))))

(defn task-dotfiles []
  (println "\n🛠️  Sincronizando Dotfiles...")

  (let [opts {:git-dir (str home "/.local/.dotfiles/")}]

    (println "⬇️ Tentando atualizar (git pull)...")
    (let [pull-res (git :pull (assoc opts :continue true))]
      (when (not= 0 (:exit pull-res))
        (println "⚠️ Falha no pull (provavelmente conflitos locais). Continuando para o commit...")))

    (let [status-out (git :status-porcelain opts)
          files-to-add (->> (str/split-lines status-out)
                            (map str/trim)
                            (filter #(re-find #"^[AMD]" %)) ;; Added, Modified ou Deleted
                            (map #(second (str/split % #"\s+" 2)))
                            (map #(str home "/"  %)))]

      (if (seq files-to-add)
        (do
          (git :add opts files-to-add)
          (git :commit opts "Update dotfiles via script")
          (git :push opts))
        (println "✨ Nada para commitar nos dotfiles.")))

    (println "✅ Sincronização finalizada.")))

(defn task-status
  "Retorna o status de todas as tarefas."
  []
  (log "Verificando Dotfiles...")
  (let [opts {:git-dir (str home "/.local/.dotfiles/")}]
    (git :status-porcelain opts))

  (log "Verificando Org..."))
  ;; (let [org-dir (fs/file home "org")]
  ;;   (if (fs/exists? org-dir)
  ;;     (shell {:dir org-dir} "git status --porcelain")
  ;;     (err (str "Diretório " org-dir " não encontrado!"))))

(defn task-all []
  (log "Executando TODAS as tarefas...")
  ;; Ordem solicitada: dotfiles, os, mise, doom, org
  (task-dotfiles)
  (task-org))

(defn print-help []
  (println "Uso: synconfig [comando]")
  (println "Comandos disponíveis: status, org, dotfiles, all"))

;; --- Main ---

(def command (first *command-line-args*))

(case command
  "org"      (task-org)
  "dotfiles" (task-dotfiles)
  "all"      (task-all)
  "status"   (task-status)
  (print-help))
