#!/bin/sh

function install_chezmoi(){
  sh -c "$(curl -fsLS get.chezmoi.io)"
}

function install_jbang(){ 
  curl -Ls https://sh.jbang.dev | bash -s - app setup
}

function install_doom(){
  # TODO verificar dependências
  # (git 2.23, emacs 28.1+, ripgrep 11.0+, find, fd)
  #
  git clone --depth 1 https://github.com/doomemacs/doomemacs ~/.config/emacs
  ~/.config/emacs/bin/doom install
}

function install_fonts(){
  fc-cache -f -v
  fc-list
}

function install_rust(){
  $ curl --proto '=https' --tlsv1.2 https://sh.rustup.rs -sSf | sh
}

function check_ripgrep(){
  [ -x "$(command -v rg)" ] && echo "ripgrep OK" || return 1
}

function check_git(){
  [ -x "$(command -v git)" ] && echo "git OK" || return 1
}

function check_fd(){
  [ -x "$(command -v fd)" ] && echo "fd OK" || return 1
}

function check_find(){
  [ -x "$(command -v find)" ] && echo "find OK" || return 1
}

function check_emacs(){
  [ -x "$(command -v emacs)" ] && echo "emacs OK" || return 1
}

function check_doom_deps(){
  check_ripgrep
  check_git
  check_fd
  check_find
  check_emacs
}

